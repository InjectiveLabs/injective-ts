{
  "name": "@injectivelabs/wallet-core",
  "description": "Core wallet strategy",
  "version": "1.16.38",
  "sideEffects": false,
  "type": "module",
  "author": {
    "name": "InjectiveLabs",
    "email": "admin@injectivelabs.org"
  },
  "license": "Apache-2.0",
  "types": "dist/cjs/index.d.ts",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "files": [
    "dist"
  ],
  "_moduleAliases": {
    "~wallet-core": "dist"
  },
  "exports": {
    ".": {
      "react-native": {
        "import": "./dist/esm/index.js",
        "require": "./dist/cjs/index.js",
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      },
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "default": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "scripts": {
    "build": "pnpm type-check && tsdown",
    "build:fast": "tsdown",
    "build:watch": "tsdown --watch",
    "clean": "shx rm -rf dist coverage *.log junit.xml && shx mkdir -p dist",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "coverage": "vitest run --coverage",
    "coverage:show": "live-server coverage",
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts,.js"
  },
  "dependencies": {
    "@injectivelabs/exceptions": "workspace:*",
    "@injectivelabs/networks": "workspace:*",
    "@injectivelabs/sdk-ts": "workspace:*",
    "@injectivelabs/ts-types": "workspace:*",
    "@injectivelabs/utils": "workspace:*",
    "@injectivelabs/wallet-base": "workspace:*",
    "@keplr-wallet/types": "^0.12.159",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "shx": "^0.3.3"
  },
  "gitHead": "6442ae377bbfb3459d2fb3a44c650630a5b7f445"
}
