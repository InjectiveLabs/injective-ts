{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "isolatedModules": true,
    "paths": {
      "@injectivelabs/utils/test-utils": [
        "../utils/src/test-utils/index.ts"
      ],
      "@injectivelabs/exceptions": [
        "../exceptions/src/index.ts"
      ]
    }
  },
  "include": [
    "./src/**/*.ts"
  ],
  "exclude": [
    "./src/**/*.spec.ts",
    "./src/**/*.test.ts"
  ]
}
