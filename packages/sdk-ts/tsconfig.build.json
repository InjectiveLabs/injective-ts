{
  "extends": "../../tsconfig.build.json",
  "compilerOptions": {
    "rootDir": "./src",
    "module": "ES2020",
    "outDir": "./dist/cjs",
    "moduleResolution": "bundler",
    "tsBuildInfoFile": "../../.build-cache/sdk-ts.tsbuildinfo"
  },
  "include": [
    "./src/**/*.ts"
  ],
  "exclude": [
    "./src/**/*.spec.ts",
    "./src/**/*.test.ts"
  ]
}
