{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noUnusedParameters": false,
    "noUnusedLocals": false,
    "paths": {
      "@injectivelabs/ts-types": [
        "packages/ts-types"
      ],
      "@injectivelabs/exceptions": [
        "packages/exceptions"
      ],
      "@injectivelabs/networks": [
        "packages/networks"
      ],
      "@injectivelabs/utils": [
        "packages/utils"
      ],
      "@injectivelabs/utils/test-utils": [
        "packages/utils/src/test-utils"
      ],
      "@injectivelabs/sdk-ts": [
        "packages/sdk-ts"
      ],
      "@injectivelabs/core-proto-ts-v2": [
        "protoV2/core/proto-ts/esm"
      ],
      "@injectivelabs/core-proto-ts-v2/generated/*": [
        "protoV2/core/proto-ts/esm/generated/*"
      ],
      "@injectivelabs/abacus-proto-ts-v2": [
        "protoV2/abacus/src"
      ],
      "@injectivelabs/abacus-proto-ts-v2/generated/*": [
        "protoV2/abacus/src/generated/*"
      ],
      "@injectivelabs/indexer-proto-ts-v2": [
        "protoV2/indexer/src"
      ],
      "@injectivelabs/indexer-proto-ts-v2/generated/*": [
        "protoV2/indexer/src/generated/*"
      ],
      "@injectivelabs/mito-proto-ts-v2": [
        "protoV2/mito/src"
      ],
      "@injectivelabs/mito-proto-ts-v2/generated/*": [
        "protoV2/mito/src/generated/*"
      ],
      "@injectivelabs/olp-proto-ts-v2": [
        "protoV2/olp/src"
      ],
      "@injectivelabs/olp-proto-ts-v2/generated/*": [
        "protoV2/olp/src/generated/*"
      ],
      "@injectivelabs/wallet-base": [
        "packages/wallets/wallet-base"
      ],
      "@injectivelabs/wallet-core": [
        "packages/wallets/wallet-core"
      ],
      "@injectivelabs/wallet-evm": [
        "packages/wallets/wallet-evm"
      ],
      "@injectivelabs/wallet-ledger": [
        "packages/wallets/wallet-ledger"
      ],
      "@injectivelabs/wallet-keplr": [
        "packages/wallets/wallet-keplr"
      ],
      "@injectivelabs/wallet-trezor": [
        "packages/wallets/wallet-trezor"
      ],
      "@injectivelabs/wallet-magic": [
        "packages/wallets/wallet-magic"
      ],
      "@injectivelabs/wallet-wallet-connect": [
        "packages/wallets/wallet-wallet-connect"
      ],
      "@injectivelabs/wallet-strategy": [
        "packages/wallets/wallet-strategy"
      ]
    }
  }
}
