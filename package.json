{
  "name": "@injectivelabs/injective-ts",
  "version": "0.0.1",
  "repository": "https://github.com/InjectiveLabs/injective-ts",
  "license": "Apache-2.0",
  "author": "@InjectiveLabs",
  "type": "module",
  "main": "index.js",
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "postinstall": "node etc/bootstrapEnv",
    "build": "node etc/bootstrapEnv && lerna run build",
    "type-check": "tsc --noEmit",
    "build:check": "pnpm type-check && pnpm build",
    "generate:mito-proto-ts": "./protoV2/mito/gen.sh",
    "publish:mito-proto-ts": "./protoV2/mito/publish.sh",
    "generate:olp-proto-ts": "./protoV2/olp/gen.sh",
    "publish:olp-proto-ts": "./protoV2/olp/publish.sh",
    "generate:core-proto-ts": "./protoV2/core/gen.sh",
    "publish:core-proto-ts": "./protoV2/core/publish.sh",
    "generate:abacus-proto-ts": "./protoV2/abacus/gen.sh",
    "publish:abacus-proto-ts": "./protoV2/abacus/publish.sh",
    "generate:tc-abacus-proto-ts": "./protoV2/tcAbacus/gen.sh",
    "publish:tc-abacus-proto-ts": "./protoV2/tcAbacus/publish.sh",
    "generate:indexer-proto-ts": "./protoV2/indexer/gen.sh",
    "publish:indexer-proto-ts": "./protoV2/indexer/publish.sh",
    "build:watch": "node etc/bootstrapEnv && lerna run build:watch --parallel --stream",
    "build:fresh": "pnpm clean-up && pnpm build:check",
    "clean-up": "lerna run clean && nx reset && shx rm -rf .build-cache *.log coverage junit.xml",
    "cache:clear": "nx reset",
    "bootstrap": "pnpm clean-up && pnpm install",
    "test:watch": "vitest",
    "test": "vitest run",
    "test:all": "vitest run; vitest run --config=vitest.broadcast.config.ts",
    "lint": "cross-env NODE_OPTIONS='--max-old-space-size=4096' lerna run lint",
    "lint:fix": "cross-env NODE_OPTIONS='--max-old-space-size=4096' lerna run lint -- --fix",
    "husky-skip": "cross-env HUSKY_SKIP_HOOKS=1",
    "link:local": "node etc/link-local.cjs",
    "commit": "git cz",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/node": "^22.17.0",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitest/ui": "^4.0.15",
    "commitizen": "^4.2.4",
    "cross-env": "^7.0.3",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.24.2",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lerna": "9.0.3",
    "lint-staged": "^16.2.7",
    "live-server": "^1.2.1",
    "markdownlint-cli": "^0.46.0",
    "nx": "^22.1.3",
    "prettier": "^3.7.4",
    "shx": "^0.4.0",
    "ts-node": "^10.9.2",
    "tsc-esm-fix": "^3.1.2",
    "tsconfig-paths": "^4.2.0",
    "tsdown": "^0.16.7",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vitest": "^4.0.15"
  },
  "private": "true",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,d.ts}": [
      "eslint --fix"
    ]
  },
  "pnpm": {
    "overrides": {
      "zod": "3.24.2",
      "rxjs": "7.8.2",
      "rpc-websockets": "9.0.4",
      "next": "file:./etc/noop",
      "@ethereumjs/tx": "^4.1.1",
      "@solana/web3.js": "1.98.0",
      "@ethereumjs/common": "3.2.0",
      "@injectivelabs/sdk-ts": "link:packages/sdk-ts"
    }
  },
  "dependencies": {
    "@injectivelabs/sdk-ts": "link:packages/sdk-ts"
  }
}
