{
  "extends": "nx/presets/npm.json",
  "tasksRunnerOptions": {
    "default": {
      "runner": "nx/tasks-runners/default",
      "options": {
        "cacheableOperations": ["build", "type-check", "test", "lint"]
      }
    }
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/package.json",
        "{workspaceRoot}/pnpm-workspace.yaml"
      ]
    },
    "type-check": {
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/package.json",
        "{workspaceRoot}/pnpm-workspace.yaml",
        "{workspaceRoot}/tsconfig.json"
      ]
    },
    "test": {
      "outputs": ["{projectRoot}/coverage"],
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/package.json",
        "{workspaceRoot}/pnpm-workspace.yaml",
        "{workspaceRoot}/vitest.config.ts"
      ]
    },
    "lint": {
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/package.json",
        "{workspaceRoot}/pnpm-workspace.yaml",
        "{workspaceRoot}/eslint.config.js"
      ]
    },
    "clean": {
      "cache": false
    }
  },
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "packages"
  },
  "affected": {
    "defaultBase": "main"
  }
}
